APP_NAME=Work Boots Console Lead Intake
APP_ENV=local
ENVIRONMENT=development
# Local quick start (no Postgres required):
DATABASE_URL=sqlite:///./local.db
# Local/dev/test convenience only. Must be false for CI/staging/production.
DB_AUTO_CREATE_LOCAL=true
# PostgreSQL option:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/work_boots_console
DEFAULT_BUSINESS_ID=11111111-1111-1111-1111-111111111111

# API CORS policy:
# - Local/dev defaults are applied in code if unset (localhost operator UI origins).
# - Production/pilot should set explicit allowed origins (comma-separated) and must not include '*'.
# API_CORS_ALLOWED_ORIGINS=https://workboots.example.com

# API response security headers
SECURITY_HEADERS_ENABLED=true
# Enable HSTS in production/pilot where TLS termination is enforced.
# SECURITY_HEADERS_HSTS_ENABLED=true
# SECURITY_HEADERS_HSTS_MAX_AGE_SECONDS=31536000

# Primary production auth path (Issue #17+):
# Bearer token -> DB lookup in api_credentials (token_hash, principal_id, business_id, is_active, revoked_at).
#
# Required in production: keyed hash pepper for token hashing.
# API_TOKEN_HASH_PEPPER=replace-with-long-random-secret
# Optional migration-only fallback for pre-pepper token hashes:
# ALLOW_LEGACY_TOKEN_HASH_FALLBACK=false

# Google authentication (identity) + internal principal authorization mapping.
GOOGLE_AUTH_ENABLED=false
# Required when GOOGLE_AUTH_ENABLED=true (and in production):
# GOOGLE_OIDC_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_OIDC_REQUIRE_EMAIL_VERIFIED=true
GOOGLE_OIDC_TIMEOUT_SECONDS=5
# Required when GOOGLE_AUTH_ENABLED=true:
# APP_SESSION_SECRET=replace-with-long-random-secret
# APP_SESSION_ISSUER=work-boots-console
# APP_SESSION_AUDIENCE=work-boots-api
# APP_SESSION_ALGORITHM=HS256
APP_SESSION_TTL_SECONDS=3600
APP_SESSION_REFRESH_TTL_SECONDS=2592000

# Google API authorization for Business Profile (separate from Google sign-in/OIDC):
# - Sign-in identifies user and maps to internal principal (`/api/auth/google/exchange`)
# - Business Profile connect is a second OAuth consent flow (`business.manage` scope)
# GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# GOOGLE_BUSINESS_PROFILE_REDIRECT_URI=https://workboots.example.com/api/integrations/google/business-profile/connect/callback
# GOOGLE_OAUTH_TOKEN_ENCRYPTION_SECRET=replace-with-long-random-secret
# GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY_VERSION=v1
# GOOGLE_BUSINESS_PROFILE_STATE_TTL_SECONDS=600

# Shared Redis for distributed rate limiting + session state/revocation.
# Pilot/prod expectation: configure REDIS_URL and use redis backends (distributed, multi-pod safe).
# REDIS_URL=redis://localhost:6379/0
# SESSION_STATE_BACKEND=auto  # auto | inmemory | redis
# SESSION_STATE_FAIL_OPEN=true  # local/dev default; set false in pilot/prod

# Application-level abuse protections
RATE_LIMIT_ENABLED=true
# RATE_LIMIT_BACKEND=auto  # auto | inmemory | redis
# RATE_LIMIT_FAIL_OPEN=true  # local/dev default; set false in pilot/prod
# Bearer-auth attempt throttling (keyed by client IP)
AUTH_RATE_LIMIT_REQUESTS=60
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# Admin-sensitive route throttling (keyed by principal + business + action + client IP)
ADMIN_RATE_LIMIT_REQUESTS=20
ADMIN_RATE_LIMIT_WINDOW_SECONDS=60

# Notification providers: mock | dev | twilio (SMS) / smtp (email)
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
NOTIFICATION_TIMEOUT_SECONDS=10

# Twilio SMS provider (required when SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+13035550123

# SMTP email provider (required when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=example-user
# SMTP_PASSWORD=example-pass
# SMTP_FROM_ADDRESS=noreply@example.com
# SMTP_USE_TLS=true

# Pilot/prod recommended security posture:
# RATE_LIMIT_BACKEND=redis
# SESSION_STATE_BACKEND=redis
# RATE_LIMIT_FAIL_OPEN=false
# SESSION_STATE_FAIL_OPEN=false
