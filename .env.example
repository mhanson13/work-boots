APP_NAME=Work Boots Console Lead Intake
ENVIRONMENT=development
# Local quick start (no Postgres required):
DATABASE_URL=sqlite:///./local.db
# PostgreSQL option:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/work_boots_console
DEFAULT_BUSINESS_ID=11111111-1111-1111-1111-111111111111

# Preferred principal-bound auth-derived tenant context (Issue #17):
# API_AUTH_PRINCIPALS_JSON is a JSON list of token->principal->business bindings.
# Example:
# API_AUTH_PRINCIPALS_JSON=[{"token":"tenant-a-token","principal_id":"user-a","business_id":"11111111-1111-1111-1111-111111111111"}]
#
# Legacy compatibility fallback (to be removed later):
# API_AUTH_TOKEN=change-me
# API_AUTH_BUSINESS_ID=11111111-1111-1111-1111-111111111111

# Notification providers: mock | dev | twilio (SMS) / smtp (email)
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
NOTIFICATION_TIMEOUT_SECONDS=10

# Twilio SMS provider (required when SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+13035550123

# SMTP email provider (required when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=example-user
# SMTP_PASSWORD=example-pass
# SMTP_FROM_ADDRESS=noreply@example.com
# SMTP_USE_TLS=true
